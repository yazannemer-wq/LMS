@{
    Layout = null;
}
@using ArkkanLMS.Core.Entities
@using ArkkanLMS.Web.Localization
@inject ArkkanLMS.Persistence.AppDbContext AppDbContext
@{
    User currentUser = null;
    if (Context.User.Identity?.IsAuthenticated == true)
    {
        var userIdValue = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdValue, out int id))
        {
            currentUser = AppDbContext.Users.Find(id);
        }
    }
    var dir = Locale.Direction;
    var lang = Locale.Culture;
    var themeAttr = Locale.Theme;
    var path = Context.Request.Path.Value ?? "/";
    string activeIf(string p) => path.StartsWith(p, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir" data-theme="@themeAttr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Locale["brand.name"] Admin</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=Poppins:wght@@500;600;700;800&family=Cairo:wght@@400;500;600;700;800&family=IBM+Plex+Sans+Arabic:wght@@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <script src="~/js/site.js"></script>
</head>
<body class="min-vh-100 app-shell role-admin">
    <div class="dashboard-shell admin-shell">
        <aside class="dashboard-sidebar p-3 admin-sidebar">
            <div class="d-flex align-items-center mb-3 px-2">
                <a class="navbar-brand font-weight-bold d-flex align-items-center mb-0" asp-area="" asp-page="/Admin/Dashboard">
                    <span class="brand-mark mr-2" aria-hidden="true"></span>
                    @Locale["brand.name"] · Admin
                </a>
            </div>

            <div class="sidebar-heading">@Locale["sb.admin.heading"]</div>
            <nav class="nav flex-column">
                <a class="nav-link @activeIf("/Admin/Dashboard")" asp-page="/Admin/Dashboard"><i class="bi bi-grid-1x2" aria-hidden="true"></i>@Locale["sb.overview"]</a>
                <a class="nav-link @activeIf("/Admin/Users")" asp-page="/Admin/Users"><i class="bi bi-people" aria-hidden="true"></i>@Locale["sb.users"]</a>
                <a class="nav-link @activeIf("/Admin/Roles")" asp-page="/Admin/Roles"><i class="bi bi-person-gear" aria-hidden="true"></i>Roles</a>
                <a class="nav-link @activeIf("/Admin/Permissions")" asp-page="/Admin/Permissions"><i class="bi bi-key" aria-hidden="true"></i>Permissions</a>
                <a class="nav-link @activeIf("/Admin/AccessControl")" asp-page="/Admin/AccessControl"><i class="bi bi-shield-check" aria-hidden="true"></i>Access Control</a>
                <a class="nav-link @activeIf("/Admin/TrainerApproval")" asp-page="/Admin/TrainerApproval"><i class="bi bi-patch-check" aria-hidden="true"></i>@Locale["sb.trainerApprovals"]</a>
                <a class="nav-link @activeIf("/Admin/CourseModeration")" asp-page="/Admin/CourseModeration"><i class="bi bi-shield-check" aria-hidden="true"></i>@Locale["sb.moderation"]</a>
                <a class="nav-link @activeIf("/Admin/Categories")" asp-page="/Admin/Categories"><i class="bi bi-tags" aria-hidden="true"></i>@Locale["sb.categories"]</a>
                <a class="nav-link @activeIf("/Admin/RevenueAnalytics")" asp-page="/Admin/RevenueAnalytics"><i class="bi bi-cash-stack" aria-hidden="true"></i>@Locale["sb.revenueAnalytics"]</a>
                <a class="nav-link @activeIf("/Admin/Coupons")" asp-page="/Admin/Coupons"><i class="bi bi-ticket-perforated" aria-hidden="true"></i>@Locale["sb.coupons"]</a>
                <a class="nav-link @activeIf("/Admin/Cms")" asp-page="/Admin/Cms"><i class="bi bi-file-earmark-text" aria-hidden="true"></i>@Locale["sb.cms"]</a>
                <a class="nav-link @activeIf("/Admin/Reports")" asp-page="/Admin/Reports"><i class="bi bi-flag" aria-hidden="true"></i>@Locale["sb.reports"]</a>
                <a class="nav-link @activeIf("/Admin/SecurityLogs")" asp-page="/Admin/SecurityLogs"><i class="bi bi-shield-lock" aria-hidden="true"></i>@Locale["sb.security"]</a>
                <a class="nav-link @activeIf("/Admin/Settings")" asp-page="/Admin/Settings"><i class="bi bi-gear" aria-hidden="true"></i>@Locale["sb.settings"]</a>
            </nav>

            <div class="mt-auto px-2 pt-3">
                <div class="glass-soft p-3">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-stars mr-2" style="color: var(--brand-3);" aria-hidden="true"></i>
                        <strong>@Locale["common.preferences"]</strong>
                    </div>
                    <div class="mb-2">@await Html.PartialAsync("_LanguageSwitcher")</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="text-muted small">@Locale["common.theme"]</span>
                        @await Html.PartialAsync("_ThemeSwitcher")
                    </div>
                </div>
            </div>
        </aside>

        <div class="dashboard-main admin-main">
            <header class="dashboard-topbar admin-topbar">
                <div class="container-fluid py-2 px-3 d-flex align-items-center justify-content-between flex-wrap" style="gap:.5rem;">
                    <button class="btn btn-outline-secondary btn-sm mobile-drawer-toggle d-lg-none" data-drawer-toggle aria-label="Menu">
                        <i class="bi bi-list" aria-hidden="true"></i>
                    </button>
                    <div class="d-none d-md-flex align-items-center dashboard-search admin-search">
                        <i class="bi bi-search mr-2" aria-hidden="true"></i>
                        <input class="form-control form-control-sm" placeholder="@Locale["common.searchPlaceholder"]" aria-label="@Locale["common.search"]" />
                    </div>

                    <div class="d-flex align-items-center" style="gap:.5rem;">
                        <button class="btn btn-outline-secondary btn-sm" type="button" title="@Locale["common.notifications"]" aria-label="@Locale["common.notifications"]">
                            <i class="bi bi-bell" aria-hidden="true"></i>
                        </button>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-inline-flex align-items-center" type="button" id="profileMenu" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="avatar avatar-sm mr-2" aria-hidden="true" style="background:linear-gradient(135deg,#0f172a,#6366f1);"><i class="bi bi-shield-lock"></i></span>
                                @(currentUser?.Name ?? "Admin")
                            </button>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="profileMenu">
                                <a class="dropdown-item" asp-page="/Admin/Settings"><i class="bi bi-gear mr-2" aria-hidden="true"></i>@Locale["sb.settings"]</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-page="/Account/Logout"><i class="bi bi-box-arrow-right mr-2" aria-hidden="true"></i>@Locale["nav.logout"]</a>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main role="main" class="p-3 p-md-4 fade-in-up">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@@4.4.3/dist/chart.umd.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
