@{
    Layout = null;
}
@using ArkkanLMS.Core.Entities
@using ArkkanLMS.Web.Localization
@inject ArkkanLMS.Persistence.AppDbContext AppDbContext
@{
    User currentUser = null;
    if (Context.User.Identity?.IsAuthenticated == true)
    {
        var userIdValue = Context.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (int.TryParse(userIdValue, out int id))
        {
            currentUser = AppDbContext.Users.Find(id);
        }
    }
    var dir = Locale.Direction;
    var lang = Locale.Culture;
    var themeAttr = Locale.Theme;
    var path = Context.Request.Path.Value ?? "/";
    string activeIf(string p) => path.StartsWith(p, StringComparison.OrdinalIgnoreCase) ? "active" : "";
}
<!DOCTYPE html>
<html lang="@lang" dir="@dir" data-theme="@themeAttr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Locale["brand.name"]</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@@400;500;600;700&family=Poppins:wght@@500;600;700;800&family=Cairo:wght@@400;500;600;700;800&family=IBM+Plex+Sans+Arabic:wght@@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/admin.css" />
    <script src="~/js/site.js"></script>
</head>
<body class="min-vh-100 app-shell role-trainer">
    <div class="dashboard-shell">
        <aside class="dashboard-sidebar p-3">
            <div class="d-flex align-items-center mb-3 px-2">
                <a class="navbar-brand font-weight-bold d-flex align-items-center mb-0" asp-area="" asp-page="/Instructor/Dashboard">
                    <span class="brand-mark mr-2" aria-hidden="true"></span>
                    @Locale["brand.name"] · Studio
                </a>
            </div>

            <div class="sidebar-heading">@Locale["sb.trainer.heading"]</div>
            <nav class="nav flex-column">
                <a class="nav-link @activeIf("/Instructor/Dashboard")" asp-page="/Instructor/Dashboard"><i class="bi bi-speedometer2" aria-hidden="true"></i>@Locale["sb.dashboard"]</a>
                <a class="nav-link @activeIf("/Trainer/Courses")" asp-page="/Trainer/Courses"><i class="bi bi-collection" aria-hidden="true"></i>@Locale["sb.myCourses"]</a>
                <a class="nav-link @activeIf("/Trainer/Builder")" asp-page="/Trainer/Builder"><i class="bi bi-grid-3x3-gap" aria-hidden="true"></i>@Locale["sb.builder"]</a>
                <a class="nav-link @activeIf("/Trainer/Analytics")" asp-page="/Trainer/Analytics"><i class="bi bi-bar-chart" aria-hidden="true"></i>@Locale["sb.analytics"]</a>
                <a class="nav-link @activeIf("/Trainer/Students")" asp-page="/Trainer/Students"><i class="bi bi-people" aria-hidden="true"></i>@Locale["sb.students"]</a>
                <a class="nav-link @activeIf("/Trainer/Assignments")" asp-page="/Trainer/Assignments"><i class="bi bi-ui-checks-grid" aria-hidden="true"></i>@Locale["sb.assignments"]</a>
                <a class="nav-link @activeIf("/Trainer/Revenue")" asp-page="/Trainer/Revenue"><i class="bi bi-cash-coin" aria-hidden="true"></i>@Locale["sb.revenue"]</a>
                <a class="nav-link @activeIf("/Trainer/Reviews")" asp-page="/Trainer/Reviews"><i class="bi bi-star" aria-hidden="true"></i>@Locale["sb.reviews"]</a>
                <a class="nav-link @activeIf("/Trainer/LiveSessions")" asp-page="/Trainer/LiveSessions"><i class="bi bi-camera-video" aria-hidden="true"></i>@Locale["sb.liveSessions"]</a>
                <a class="nav-link @activeIf("/Trainer/Sessions")" asp-page="/Trainer/Sessions"><i class="bi bi-calendar-week" aria-hidden="true"></i>@Locale["sb.sessions"]</a>
                <a class="nav-link @activeIf("/Profile")" asp-page="/Profile/Index"><i class="bi bi-gear" aria-hidden="true"></i>@Locale["sb.settings"]</a>
            </nav>

            <div class="mt-auto px-2 pt-3">
                <div class="glass-soft p-3">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-stars mr-2" style="color: var(--brand-1);" aria-hidden="true"></i>
                        <strong>@Locale["common.preferences"]</strong>
                    </div>
                    <div class="mb-2">@await Html.PartialAsync("_LanguageSwitcher")</div>
                    <div class="d-flex align-items-center justify-content-between">
                        <span class="text-muted small">@Locale["common.theme"]</span>
                        @await Html.PartialAsync("_ThemeSwitcher")
                    </div>
                </div>
            </div>
        </aside>

        <div class="dashboard-main">
            <header class="dashboard-topbar">
                <div class="container-fluid py-2 px-3 d-flex align-items-center justify-content-between flex-wrap" style="gap:.5rem;">
                    <button class="btn btn-outline-secondary btn-sm mobile-drawer-toggle d-lg-none" data-drawer-toggle aria-label="Menu">
                        <i class="bi bi-list" aria-hidden="true"></i>
                    </button>
                    <div class="d-flex align-items-center" style="gap:.5rem;">
                        <a class="btn btn-primary btn-sm" asp-page="/Trainer/Builder">
                            <i class="bi bi-plus-lg mr-2" aria-hidden="true"></i>@Locale["sb.createCourse"]
                        </a>
                        <span class="text-muted small d-none d-md-inline">@Locale["trainer.kpi.revenue"]: <strong class="text-grad">$3,420</strong></span>
                    </div>

                    <div class="d-flex align-items-center" style="gap:.5rem;">
                        <button class="btn btn-outline-secondary btn-sm" type="button" title="@Locale["common.notifications"]" aria-label="@Locale["common.notifications"]">
                            <i class="bi bi-bell" aria-hidden="true"></i>
                        </button>
                        <div class="dropdown">
                            <button class="btn btn-outline-secondary btn-sm dropdown-toggle d-inline-flex align-items-center" type="button" id="profileMenu" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                <span class="avatar avatar-sm mr-2" aria-hidden="true">@(currentUser?.Name?.Substring(0,1) ?? "T")</span>
                                @(currentUser?.Name ?? "Trainer")
                            </button>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="profileMenu">
                                <a class="dropdown-item" asp-page="/Profile/Index"><i class="bi bi-person mr-2" aria-hidden="true"></i>@Locale["profile.tab.personal"]</a>
                                <a class="dropdown-item" asp-page="/Trainer/Revenue"><i class="bi bi-cash-coin mr-2" aria-hidden="true"></i>@Locale["sb.revenue"]</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item" asp-page="/Account/Logout"><i class="bi bi-box-arrow-right mr-2" aria-hidden="true"></i>@Locale["nav.logout"]</a>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main role="main" class="p-3 p-md-4 fade-in-up">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@@4.4.3/dist/chart.umd.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
