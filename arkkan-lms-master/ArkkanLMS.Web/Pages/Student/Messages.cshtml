@page
@using ArkkanLMS.Web.Localization
@model ArkkanLMS.Web.Pages.Student.MessagesModel
@{
    ViewData["Title"] = Locale["sb.messages"];
    Layout = "_StudentLayout";
    var isAr = Locale.IsRtl;
}

<div class="mb-4">
    <h2 class="mb-1"><i class="bi bi-chat-dots mr-2"></i>@Locale["sb.messages"]</h2>
    <div class="text-muted">@(isAr ? "محادثاتك مع المدرّبين والزملاء." : "Conversations with instructors and peers.")</div>
</div>

<div class="row">
    <div class="col-md-5 col-lg-4 mb-3">
        <div class="card feature-card h-100">
            <div class="card-body p-2">
                <div class="dashboard-search mx-2 my-2">
                    <i class="bi bi-search mr-2"></i>
                    <input class="form-control form-control-sm" placeholder="@(isAr ? "ابحث في الرسائل..." : "Search messages...")" />
                </div>
                @{ int idx = 0; }
                @foreach (var m in DemoData.Messages)
                {
                    idx++;
                    var rowClass = (idx == 1 ? "active " : "") + (m.Unread ? "unread" : "");
                    <div class="message-row @rowClass" style="@(idx == 1 ? "background:var(--brand-soft); border-color:rgba(79,70,229,.25);" : "")">
                        <span class="avatar avatar-sm">@m.Initials</span>
                        <div class="flex-fill" style="min-width:0;">
                            <div class="msg-meta">
                                <span class="msg-name">@(isAr ? m.FromAr : m.FromEn)</span>
                                <span class="msg-time">@(isAr ? m.TimeAr : m.TimeEn)</span>
                            </div>
                            <div class="msg-preview" style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@(isAr ? m.PreviewAr : m.PreviewEn)</div>
                        </div>
                        @if (m.Unread)
                        {
                            <span class="badge-soft" style="background:var(--brand-1); color:#fff; border-color:transparent; padding:.1rem .35rem; font-size:.65rem;">@(isAr ? "جديد" : "NEW")</span>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-md-7 col-lg-8 mb-3">
        <div class="card feature-card h-100 d-flex flex-column">
            <div class="card-body d-flex align-items-center pb-3 border-bottom" style="gap:.65rem; border-color:var(--stroke);">
                <span class="avatar">SK</span>
                <div class="flex-fill">
                    <div class="font-weight-bold">@(isAr ? "سارة خالد" : "Sara Khalid")</div>
                    <div class="text-muted small">@(isAr ? "متصلة الآن" : "Online now") · <span style="color:var(--success)">●</span></div>
                </div>
                <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-camera-video"></i></button>
                <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-three-dots"></i></button>
            </div>
            <div class="card-body" style="flex:1; min-height: 360px;">
                <div class="message-row mb-2" style="border:0;">
                    <span class="avatar avatar-sm">SK</span>
                    <div class="flex-fill">
                        <div class="msg-meta"><span class="msg-name">@(isAr ? "سارة خالد" : "Sara Khalid")</span><span class="msg-time">12:08</span></div>
                        <div class="p-2 mt-1 d-inline-block" style="background:var(--surface-soft); border:1px solid var(--stroke); border-radius:14px;">@(isAr ? "إجابة ممتازة على واجب React — هناك ملاحظات بسيطة في الداخل." : "Great submission on the React assignment — minor feedback inside.")</div>
                    </div>
                </div>
                <div class="d-flex flex-row-reverse mb-2">
                    <div style="max-width:70%;">
                        <div class="text-muted small text-right">@(isAr ? "أنت · 12:14" : "You · 12:14")</div>
                        <div class="p-2" style="background:var(--accent-fill-strong); color:#fafaf9; border-radius:14px; border:1px solid var(--stroke);">@(isAr ? "شكرًا سارة! سأطّلع عليها وأرد سريعًا." : "Thanks Sara! I'll review and respond shortly.")</div>
                    </div>
                </div>
                <div class="message-row mb-2" style="border:0;">
                    <span class="avatar avatar-sm">SK</span>
                    <div class="flex-fill">
                        <div class="msg-meta"><span class="msg-name">@(isAr ? "سارة خالد" : "Sara Khalid")</span><span class="msg-time">12:18</span></div>
                        <div class="p-2 mt-1 d-inline-block" style="background:var(--surface-soft); border:1px solid var(--stroke); border-radius:14px;">@(isAr ? "ممتاز. تذكير: جلسة المجموعة غدًا 17:30." : "Perfect. Reminder: cohort sync tomorrow at 17:30.")</div>
                    </div>
                </div>
            </div>
            <div class="card-body pt-3 border-top" style="border-color:var(--stroke);">
                <div class="d-flex" style="gap:.5rem;">
                    <button class="btn btn-outline-secondary"><i class="bi bi-paperclip"></i></button>
                    <input class="form-control" placeholder="@(isAr ? "اكتب رسالة..." : "Type a message...")" />
                    <button class="btn btn-primary"><i class="bi bi-send"></i></button>
                </div>
            </div>
        </div>
    </div>
</div>
