@page
@model ErrorModel
@{
    ViewData["Title"] = "Something went wrong";
}

<div class="card feature-card">
    <div class="card-body p-4 p-md-5 text-center">
        <div class="mb-3" style="font-size:2rem; line-height:1;">
            <i class="bi bi-exclamation-triangle"></i>
        </div>
        <h1 class="h3 mb-2">We hit an unexpected error</h1>
        <p class="text-muted mb-4">Please try again. If the problem persists, share the request id with support.</p>

        @if (Model.ShowRequestId)
        {
            <div class="d-inline-flex align-items-center px-3 py-2 mb-4" style="border:1px solid var(--stroke); border-radius:12px; background: var(--surface-soft); gap:.5rem;">
                <span class="text-muted small">Request ID</span>
                <code>@Model.RequestId</code>
            </div>
        }

        <div class="d-flex flex-column flex-sm-row justify-content-center" style="gap:.75rem;">
            <a class="btn btn-primary" asp-page="/Index"><i class="bi bi-house-door mr-2"></i>Go home</a>
            <a class="btn btn-outline-secondary" asp-page="/Courses/Index"><i class="bi bi-journal-bookmark mr-2"></i>Browse courses</a>
        </div>
    </div>
</div>

