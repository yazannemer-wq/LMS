@page "{id:int}"
@model ArkkanLMS.Web.Pages.Courses.DetailsModel
@{
    ViewData["Title"] = "Course details";
}

<section class="hero text-center py-5">
    <div class="container">
        <p class="text-uppercase text-primary font-weight-bold mb-3"><i class="bi bi-journal-text mr-2" aria-hidden="true"></i>Course</p>
        <h1 class="display-4 font-weight-bold mb-3">@Model.Course?.Name</h1>
        <p class="lead mx-auto mb-0" style="max-width: 760px;">@Model.Course?.Description</p>
    </div>
</section>

<div class="container py-4">
    @if (Model.Course == null)
    {
        <div class="alert alert-danger">Course not found.</div>
    }
    else
    {
        <div class="row">
            <div class="col-lg-8 mb-4">
                <div class="card feature-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between flex-wrap">
                            <div>
                                <div class="text-muted mb-1">Type</div>
                                <span class="badge badge-primary">@Model.Course.CourseType</span>
                            </div>
                            <div class="mt-3 mt-md-0">
                                @if (Model.IsTrainee)
                                {
                                    <a class="btn btn-primary" asp-page="/Courses/Register" asp-route-id="@Model.Course.Id">
                                        <i class="bi bi-ticket-perforated mr-2" aria-hidden="true"></i>Register
                                    </a>
                                }
                                else if (!Model.HasCurrentUser)
                                {
                                    <a class="btn btn-primary" asp-page="/Account/Login">
                                        <i class="bi bi-box-arrow-in-right mr-2" aria-hidden="true"></i>Log in to register
                                    </a>
                                }
                            </div>
                        </div>

                        <hr />

                        <h5 class="mb-3"><i class="bi bi-collection-play mr-2" aria-hidden="true"></i>Lessons</h5>
                        @if (Model.Course.CourseLessons == null || !Model.Course.CourseLessons.Any())
                        {
                            <div class="text-muted">No lessons have been added yet.</div>
                        }
                        else
                        {
                            <div class="list-group">
                                @foreach (var lesson in Model.Course.CourseLessons.OrderBy(l => l.Id))
                                {
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="font-weight-bold">@lesson.Name</div>
                                            <div class="text-muted small">@lesson.LessonType</div>
                                        </div>
                                        <span class="text-muted small">Planned: video player/resources</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="col-lg-4 mb-4">
                <div class="card feature-card h-100">
                    <div class="card-body">
                        <h5 class="mb-3"><i class="bi bi-calendar-event mr-2" aria-hidden="true"></i>Open sessions</h5>
                        @if (Model.OpenSessions == null || !Model.OpenSessions.Any())
                        {
                            <div class="text-muted">No open sessions available.</div>
                        }
                        else
                        {
                            <ul class="text-muted mb-0">
                                @foreach (var s in Model.OpenSessions.OrderBy(s => s.StartTime))
                                {
                                    <li>@s.Title — @s.StartTime.ToLocalTime():g</li>
                                }
                            </ul>
                        }
                        <hr />
                        <div class="text-muted small">Planned: wishlist, notes, discussion, quizzes, progress, certificates.</div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

