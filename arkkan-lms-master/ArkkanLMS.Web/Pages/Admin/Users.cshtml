@page
@model ArkkanLMS.Web.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Manage Users";
    Layout = "_AdminLayout";
}

<h1>Manage Users</h1>

@if (!Model.HasCurrentUser)
{
    <div class="alert alert-warning">Please sign in. <a asp-page="/Account/Login">Log in</a></div>
}
else if (!Model.IsCurrentUserRole(ArkkanLMS.Core.Types.UserRoleType.Admin))
{
    <div class="alert alert-danger">Only admins can manage user roles.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>
                        <form method="post" class="form-inline">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-control mr-2">
                                @foreach (var role in Model.RoleOptions)
                                {
                                    <option value="@role.Value" selected="@(role.Value == ((int)user.Role).ToString() ? "selected" : null)">@role.Text</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-primary">Save</button>
                        </form>
                    </td>
                    <td>@(user.Id == Model.CurrentUser.Id ? "(current)" : "")</td>
                </tr>
            }
        </tbody>
    </table>
}

