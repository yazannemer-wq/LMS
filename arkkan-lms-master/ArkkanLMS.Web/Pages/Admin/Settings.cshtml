@page
@model ArkkanLMS.Web.Pages.Admin.SettingsModel
@{
    ViewData["Title"] = "Admin settings";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-start align-items-md-center mb-4 flex-column flex-md-row">
    <div>
        <h2 class="mb-1">Settings</h2>
        <div class="text-muted">Platform settings and configuration (planned).</div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 mb-3">
        <div class="card feature-card">
            <div class="card-body">
                <h5 class="mb-2"><i class="bi bi-sliders mr-2" aria-hidden="true"></i>Platform</h5>
                <div class="text-muted">Planned: subscription plans, coupons, CMS, notification providers, and feature flags.</div>
            </div>
        </div>
    </div>
    <div class="col-lg-6 mb-3">
        <div class="card feature-card">
            <div class="card-body">
                <h5 class="mb-2"><i class="bi bi-shield-check mr-2" aria-hidden="true"></i>Security</h5>
                <div class="text-muted">Planned: password policies, admin audit logs, and IP allowlists.</div>
            </div>
        </div>
    </div>
</div>

