@page
@using ArkkanLMS.Web.Localization
@inject LocaleProvider Locale
@{
    ViewData["Title"] = Locale.IsRtl ? "صيانة" : "Maintenance";
    var isAr = Locale.IsRtl;
}

<div class="card feature-card">
    <div class="card-body p-4 p-md-5 text-center">
        <div class="mb-3" style="font-size:2.25rem; line-height:1;">
            <i class="bi bi-wrench-adjustable-circle"></i>
        </div>
        <div class="text-faint small mb-2">503</div>
        <h1 class="h3 mb-2">@(isAr ? "نقوم بأعمال صيانة" : "We’re down for maintenance")</h1>
        <p class="text-muted mb-4">
            @(isAr ? "سنعود قريبًا. شكرًا لصبرك." : "We’ll be back shortly. Thanks for your patience.")
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center" style="gap:.75rem;">
            <a class="btn btn-outline-secondary" asp-page="/Index"><i class="bi bi-house-door mr-2"></i>@(isAr ? "الرئيسية" : "Home")</a>
            <a class="btn btn-primary" href="javascript:location.reload()"><i class="bi bi-arrow-repeat mr-2"></i>@(isAr ? "إعادة المحاولة" : "Try again")</a>
        </div>
    </div>
</div>

