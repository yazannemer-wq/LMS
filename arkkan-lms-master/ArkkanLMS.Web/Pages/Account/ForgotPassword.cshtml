@page
@using ArkkanLMS.Web.Localization
@model ArkkanLMS.Web.Pages.Account.ForgotPasswordModel
@{
    ViewData["Title"] = "Forgot password";
    var isAr = Model.Locale?.IsRtl ?? false;
}

<section class="hero text-center" style="padding: 3rem 0 1rem;">
    <div class="container">
        <span class="hero-eyebrow"><i class="bi bi-envelope-check"></i> @(isAr ? "استعادة كلمة المرور" : "Password recovery")</span>
        <h1 class="display-4 font-weight-bold mt-3 mb-2">@(isAr ? "إعادة تعيين كلمة المرور" : "Reset your password")</h1>
        <p class="lead">@(isAr ? "أدخل بريدك الإلكتروني وسنرسل تعليمات إعادة التعيين." : "Enter your email and we’ll send reset instructions.")</p>
    </div>
</section>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card feature-card">
                <div class="card-body p-4">
                    @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
                    {
                        <div class="alert alert-success">@Model.SuccessMessage</div>
                    }

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
                        <div class="form-group mb-3">
                            <label asp-for="Input.Email" class="text-faint small">@(isAr ? "البريد الإلكتروني" : "Email")</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-column flex-sm-row" style="gap:.75rem;">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send mr-2"></i>@(isAr ? "إرسال" : "Send instructions")
                            </button>
                            <a asp-page="/Account/Login" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left mr-2"></i>@(isAr ? "العودة لتسجيل الدخول" : "Back to login")
                            </a>
                        </div>
                    </form>

                    <div class="text-faint small mt-3">
                        <i class="bi bi-info-circle mr-2"></i>
                        @(isAr ? "لن نكشف إن كان البريد مسجلًا أم لا." : "We won’t reveal whether an email is registered.")
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

