@page
@using ArkkanLMS.Web.Localization
@model ArkkanLMS.Web.Pages.Account.RegisterModel
@{
    ViewData["Title"] = "Register";
    var isAr = Model.Locale?.IsRtl ?? false;
}

<section class="hero text-center" style="padding: 3rem 0 1rem;">
    <div class="container">
        <span class="hero-eyebrow"><i class="bi bi-person-plus"></i> @(isAr ? "حساب جديد" : "New account")</span>
        <h1 class="display-4 font-weight-bold mt-3 mb-2">@(isAr ? "إنشاء حساب متدرب" : "Create a trainee account")</h1>
        <p class="lead">@(isAr ? "سجّل الآن وابدأ بحجز الدورات." : "Register to book courses and sessions.")</p>
    </div>
</section>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">
            <div class="card feature-card">
                <div class="card-body p-4">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Name" class="text-faint small">@(isAr ? "الاسم" : "Name")</label>
                            <input asp-for="Input.Name" class="form-control" />
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Email" class="text-faint small">@(isAr ? "البريد الإلكتروني" : "Email")</label>
                            <input asp-for="Input.Email" class="form-control" placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Input.Password" class="text-faint small">@(isAr ? "كلمة المرور" : "Password")</label>
                            <input asp-for="Input.Password" class="form-control" type="password" placeholder="••••••••" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Input.ConfirmPassword" class="text-faint small">@(isAr ? "تأكيد كلمة المرور" : "Confirm password")</label>
                            <input asp-for="Input.ConfirmPassword" class="form-control" type="password" placeholder="••••••••" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <div class="d-flex flex-column flex-sm-row" style="gap:.75rem;">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-person-check mr-2"></i>@(isAr ? "إنشاء الحساب" : "Create account")
                            </button>
                            <a asp-page="/Account/Login" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left mr-2"></i>@(isAr ? "لدي حساب بالفعل" : "I already have an account")
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}

