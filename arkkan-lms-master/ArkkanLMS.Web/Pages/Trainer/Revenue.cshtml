@page
@using ArkkanLMS.Web.Localization
@model ArkkanLMS.Web.Pages.Trainer.RevenueModel
@{
    ViewData["Title"] = Locale["sb.revenue"];
    Layout = "_TrainerLayout";
    var isAr = Locale.IsRtl;
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap" style="gap:1rem;">
    <div>
        <h2 class="mb-1"><i class="bi bi-cash-coin mr-2"></i>@Locale["sb.revenue"]</h2>
        <div class="text-muted">@(isAr ? "إيراداتك ودفعاتك المستقبلية." : "Your earnings and upcoming payouts.")</div>
    </div>
    <button class="btn btn-primary"><i class="bi bi-bank mr-2"></i>@(isAr ? "اطلب صرف" : "Request payout")</button>
</div>

<div class="row">
    @foreach (var k in new[] {
        ("bi-cash-stack", isAr ? "إجمالي الإيرادات" : "Total revenue", "$184,210", "+12.4%", true,  "#16a34a"),
        ("bi-wallet2",    isAr ? "متاح للسحب"      : "Available",       "$3,420",   "",        true,  "#4f46e5"),
        ("bi-clock-history", isAr ? "قيد المعالجة" : "Pending",          "$642",     "",        true,  "#f59e0b"),
        ("bi-receipt",    isAr ? "إيرادات الشهر"  : "This month",        "$8,940",   "+18.4%", true,  "#7c3aed"),
    })
    {
        <div class="col-lg-3 col-md-6 mb-3">
            <div class="card kpi-card h-100"><div class="card-body">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <div class="text-muted"><i class="bi @k.Item1 mr-2" style="color:@k.Item6"></i>@k.Item2</div>
                    @if (!string.IsNullOrEmpty(k.Item4)) { <span class="kpi-trend-up small"><i class="bi bi-arrow-up-right"></i> @k.Item4</span> }
                </div>
                <div class="kpi-value">@k.Item3</div>
            </div></div>
        </div>
    }
</div>

<div class="row">
    <div class="col-lg-8 mb-3">
        <div class="card chart-card"><div class="card-body">
            <h5 class="mb-3"><i class="bi bi-graph-up-arrow mr-2"></i>@(isAr ? "اتجاه الإيرادات" : "Revenue trend")</h5>
            <canvas id="rev" height="110"></canvas>
        </div></div>
    </div>
    <div class="col-lg-4 mb-3">
        <div class="card chart-card h-100"><div class="card-body">
            <h5 class="mb-3"><i class="bi bi-pie-chart mr-2"></i>@(isAr ? "توزيع الإيرادات" : "Revenue split")</h5>
            <canvas id="split" height="160"></canvas>
        </div></div>
    </div>
</div>

<div class="card feature-card mt-2">
    <div class="card-body">
        <h5 class="mb-3"><i class="bi bi-list-ul mr-2"></i>@(isAr ? "آخر المعاملات" : "Recent transactions")</h5>
        <table class="table table-hover mb-0">
            <thead>
                <tr><th>@(isAr ? "التاريخ" : "Date")</th><th>@(isAr ? "النوع" : "Type")</th><th>@(isAr ? "الدورة" : "Course")</th><th>@(isAr ? "الطالب" : "Student")</th><th class="text-right">@(isAr ? "المبلغ" : "Amount")</th></tr>
            </thead>
            <tbody>
                <tr><td>@(isAr ? "اليوم 12:08" : "Today 12:08")</td><td><span class="badge-soft badge-success"><i class="bi bi-arrow-down-left"></i> @(isAr ? "بيع" : "Sale")</span></td><td>Advanced React</td><td>Aisha M.</td><td class="text-right text-success"><strong>+$79</strong></td></tr>
                <tr><td>@(isAr ? "اليوم 11:42" : "Today 11:42")</td><td><span class="badge-soft badge-success"><i class="bi bi-arrow-down-left"></i> @(isAr ? "بيع" : "Sale")</span></td><td>ML A–Z</td><td>Daniel P.</td><td class="text-right text-success"><strong>+$99</strong></td></tr>
                <tr><td>@(isAr ? "أمس 18:00" : "Yesterday 18:00")</td><td><span class="badge-soft badge-warning"><i class="bi bi-arrow-counterclockwise"></i> @(isAr ? "استرداد" : "Refund")</span></td><td>Cloud Pro</td><td>Anonymous</td><td class="text-right text-danger"><strong>-$129</strong></td></tr>
                <tr><td>@(isAr ? "أمس 15:30" : "Yesterday 15:30")</td><td><span class="badge-soft badge-info"><i class="bi bi-bank"></i> @(isAr ? "صرف" : "Payout")</span></td><td>—</td><td>—</td><td class="text-right"><strong>-$2,800</strong></td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
  (function(){
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
    const grid = isDark ? 'rgba(148,163,184,.18)' : 'rgba(148,163,184,.25)';
    const text = isDark ? '#cbd5e1' : '#475569';
    const r = document.getElementById('rev');
    if (r && window.Chart) new Chart(r,{type:'line',data:{labels:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'], datasets:[{label:'2026', data:[4200,5300,6100,7400,8200,9100,9800,10400,11200,12100,13400,14800], borderColor:'#16a34a', backgroundColor:'rgba(16,185,129,.18)', fill:true, tension:.4, pointRadius:0},{label:'2025', data:[3000,3400,3800,4200,4500,5100,5400,5900,6300,6900,7400,7800], borderColor:'rgba(124,58,237,.55)', borderDash:[4,4], pointRadius:0}]}, options:{responsive:true, plugins:{legend:{labels:{color:text}}}, scales:{y:{ticks:{color:text, callback:v=>'$'+v}, grid:{color:grid}}, x:{ticks:{color:text}, grid:{display:false}}}}});
    const s = document.getElementById('split');
    if (s && window.Chart) new Chart(s,{type:'doughnut', data:{labels:['Advanced React','ML A–Z','Figma','Cloud Pro','Cybersec'], datasets:[{ data:[42,28,12,11,7], backgroundColor:['#4f46e5','#7c3aed','#fb7185','#0ea5e9','#16a34a'], borderWidth:0 }]}, options:{cutout:'62%', plugins:{legend:{position:'bottom', labels:{color:text}}}}});
  })();
</script>
}
