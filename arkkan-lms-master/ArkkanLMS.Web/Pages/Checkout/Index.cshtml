@page
@model ArkkanLMS.Web.Pages.Checkout.IndexModel
@{
    ViewData["Title"] = "Checkout";
}

<section class="hero text-center py-5">
    <div class="container">
        <p class="text-uppercase text-primary font-weight-bold mb-3"><i class="bi bi-credit-card mr-2" aria-hidden="true"></i>Payments</p>
        <h1 class="display-4 font-weight-bold mb-3">Checkout (Demo)</h1>
        <p class="lead mx-auto mb-0" style="max-width: 760px;">This is a placeholder checkout page. Payment providers (Stripe, etc.) are not integrated yet.</p>
    </div>
</section>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-7 mb-4">
            <div class="card feature-card">
                <div class="card-body">
                    <h5 class="mb-3">Order summary</h5>
                    <div class="d-flex justify-content-between text-muted">
                        <span>Plan</span>
                        <span>Pro (Demo)</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted">
                        <span>Subtotal</span>
                        <span>$29.00</span>
                    </div>
                    <div class="d-flex justify-content-between text-muted">
                        <span>Tax</span>
                        <span>$0.00</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between">
                        <strong>Total</strong>
                        <strong>$29.00</strong>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5 mb-4">
            <div class="card feature-card h-100">
                <div class="card-body">
                    <h5 class="mb-3">Payment method</h5>
                    <div class="text-muted">Planned: card form, coupons, subscription plans, and provider webhooks.</div>
                    <hr />
                    <a class="btn btn-primary btn-block" asp-page="/Account/Login"><i class="bi bi-lock mr-2" aria-hidden="true"></i>Continue (demo)</a>
                </div>
            </div>
        </div>
    </div>
</div>

