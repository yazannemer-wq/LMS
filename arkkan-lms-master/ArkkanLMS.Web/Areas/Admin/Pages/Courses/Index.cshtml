@page
@model ArkkanLMS.Web.Areas.Admin.Pages.Courses.IndexModel

@{
    ViewData["Title"] = "All Courses";
}

<section class="hero text-center py-4">
    <div class="container">
        <h1 class="display-5 font-weight-bold mb-3">Manage Courses</h1>
        <p class="lead mx-auto mb-4" style="max-width: 600px;">View, edit, and organize all course offerings in the system.</p>
        <a class="btn btn-success btn-lg" asp-page="Create">Create New Course</a>
    </div>
</section>

<div class="container py-4">
    @if (Model.Courses.Any())
    {
        <div class="row">
            @foreach (var item in Model.Courses)
            {
                <div class="col-lg-6 col-xl-4 mb-4">
                    <div class="card course-card h-100 shadow-sm">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@item.Name</h5>
                            <p class="card-text flex-grow-1">@item.Description</p>
                            <div class="mb-3">
                                <span class="badge badge-primary mr-2">@item.CourseType</span>
                                @if (!string.IsNullOrEmpty(item.CourseImageURL))
                                {
                                    <small class="text-muted">Has image</small>
                                }
                            </div>
                            <div class="text-muted small mb-3">
                                <div>Created: @item.DateCreated.ToShortDateString()</div>
                                <div>Updated: @item.DateUpdated.ToShortDateString()</div>
                            </div>
                            <div class="d-flex justify-content-between">
                                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm">Edit</a>
                                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm">Details</a>
                                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm">Delete</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <h3 class="text-muted">No courses found.</h3>
            <p class="text-muted">Start by creating your first course.</p>
            <a class="btn btn-success" asp-page="Create">Create New Course</a>
        </div>
    }
</div>


