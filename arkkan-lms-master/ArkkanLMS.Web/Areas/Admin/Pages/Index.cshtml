@page
@model IndexModel
@{
    ViewData["Title"] = "ArkkanLMS Administration";
}

<section class="hero text-center py-5">
    <div class="container">
        <h1 class="display-4 font-weight-bold mb-3">ArkkanLMS Administration</h1>
        <p class="lead mx-auto mb-4" style="max-width: 600px;">Manage courses, authors, and users from your centralized admin dashboard.</p>
    </div>
</section>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card admin-card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Courses</h5>
                    <p class="card-text">Create, edit, and manage course offerings.</p>
                    <a asp-area="Admin" asp-page="/Courses/Index" class="btn btn-primary">Manage Courses</a>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card admin-card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Authors</h5>
                    <p class="card-text">Oversee course authors and their profiles.</p>
                    <a asp-area="Admin" asp-page="/Authors/Index" class="btn btn-primary">Manage Authors</a>
                </div>
            </div>
        </div>
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card admin-card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Users</h5>
                    <p class="card-text">View and manage system users.</p>
                    <a asp-page="/Admin/Users" class="btn btn-primary">View Users</a>
                </div>
            </div>
        </div>
    </div>
</div>


